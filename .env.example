# TeamClaw Environment Configuration

# Session secret (required in production, auto-generated in development)
# Generate: openssl rand -base64 32
SESSION_SECRET=

# Session expiry in hours (default: 24, 168 = 7 days)
SESSION_EXPIRY_HOURS=168

# App base URL (required, used by MCP handler and template engine)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# JWT signing secret (required in production, min 32 chars)
# Generate: openssl rand -base64 48
JWT_SECRET=

# Allowed CORS origins (comma-separated, recommended in production)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Initialization mode (set to "true" to enable first-run setup)
# ENABLE_INITIALIZATION=true

# OpenClaw API Token (for local AI agent calls)
OPENCLAW_TOKEN=

# OpenClaw Gateway WebSocket URL (default: ws://localhost:18789)
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18789

# OpenClaw HTTP endpoint (default: http://127.0.0.1:18789)
OPENCLAW_DEFAULT_ENDPOINT=http://127.0.0.1:18789

# Token encryption key (required in production, auto-generated in development)
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# MCP Token encryption key (required in production, min 32 chars)
# Generate: openssl rand -hex 32
MCP_TOKEN_KEY=

# Database path (optional, default: data/teamclaw.db)
# TEAMCLAW_DB_PATH=/path/to/data/teamclaw.db
