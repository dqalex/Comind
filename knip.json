{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "project": [
    "**/*.{ts,tsx}"
  ],
  "ignore": [
    "**/*.d.ts",
    "**/*.config.{ts,js}",
    "**/generated/**",
    "**/__mocks__/**",
    "lib/chat-channel/**",
    "lib/api-route-factory.ts",
    "lib/api-utils.ts"
  ],
  "ignoreDependencies": [
    "@types/*",
    "typescript",
    "vitest",
    "@playwright/test"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "warn",
    "dependencies": "warn",
    "devDependencies": "off",
    "exports": "warn",
    "types": "warn"
  }
}
